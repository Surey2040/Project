# ---- Server ----
PORT=4000
NODE_ENV=production

# ---- Database ----
DATABASE_URL="postgresql://user:password@localhost:5432/kgisl_attendance?schema=public"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- JWT ----
JWT_ACCESS_SECRET="replace-with-64-byte-random-secret"
JWT_ACCESS_TTL="15m"

# Separate secret for refresh tokens (never reuse the access-token secret).
JWT_REFRESH_SECRET="replace-with-a-different-64-byte-random-secret"
JWT_REFRESH_TTL_SECONDS=604800

# ---- Auth brute-force protection ----
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ---- QR / HMAC ----
# 256-bit (32 byte) hex key used to HMAC-SHA256 sign every QR payload.
QR_HMAC_SECRET="replace-with-64-hex-char-random-key"
QR_REFRESH_INTERVAL_SECONDS=10
QR_CLOCK_SKEW_TOLERANCE_SECONDS=2

# ---- Geofence ----
DEFAULT_GEOFENCE_RADIUS_M=120

# ---- Rate Limiting ----
SCAN_RATE_LIMIT_WINDOW_MS=60000
SCAN_RATE_LIMIT_MAX=10

# ---- CORS ----
# Comma-separated list of frontend origins allowed to call the API / connect via WebSocket
FRONTEND_ORIGINS="http://localhost:5173"
